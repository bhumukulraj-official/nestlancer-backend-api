{
    "name": "nestlancer-backend-api",
    "version": "1.0.0",
    "description": "Nestlancer – A freelancing platform backend built as a NestJS monorepo",
    "private": true,
    "license": "MIT",
    "author": "Nestlancer Team",
    "packageManager": "pnpm@9.15.4",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    },
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "test": "turbo test",
        "test:unit": "turbo test:unit",
        "test:integration": "turbo test:integration",
        "test:e2e": "turbo test:e2e",
        "test:cov": "turbo test:cov",
        "lint": "turbo lint",
        "lint:fix": "turbo lint:fix",
        "format": "prettier --write \"**/*.{ts,json,md,yaml,yml}\"",
        "format:check": "prettier --check \"**/*.{ts,json,md,yaml,yml}\"",
        "db:migrate": "prisma migrate dev --schema=prisma/schema/schema.prisma",
        "db:migrate:deploy": "prisma migrate deploy --schema=prisma/schema/schema.prisma",
        "db:seed": "prisma db seed",
        "db:reset": "prisma migrate reset --schema=prisma/schema/schema.prisma",
        "db:generate": "prisma generate --schema=prisma/schema/schema.prisma",
        "db:studio": "prisma studio --schema=prisma/schema/schema.prisma",
        "docker:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
        "docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
        "docker:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml up -d",
        "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
        "clean": "turbo clean && rm -rf node_modules dist coverage .turbo",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.6.1",
        "@commitlint/config-conventional": "^19.6.0",
        "@nestjs/cli": "^10.4.9",
        "@nestjs/schematics": "^10.2.3",
        "@nestjs/testing": "^10.4.15",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.17.12",
        "@typescript-eslint/eslint-plugin": "^8.20.0",
        "@typescript-eslint/parser": "^8.20.0",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-prettier": "^5.2.3",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "lint-staged": "^15.4.3",
        "prettier": "^3.4.2",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "turbo": "^2.3.4",
        "typescript": "^5.7.3"
    },
    "prisma": {
        "schema": "prisma/schema/schema.prisma",
        "seed": "ts-node prisma/seeds/index.ts"
    }
}