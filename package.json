{
    "name": "nestlancer-backend-api",
    "version": "1.0.0",
    "description": "Nestlancer – A freelancing platform backend built as a NestJS monorepo",
    "private": true,
    "license": "MIT",
    "author": "Nestlancer Team",
    "packageManager": "pnpm@9.15.4",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    },
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "build:log": "turbo run build --continue --force --parallel 2>&1 | tee build.log.txt",
        "test": "turbo test",
        "test:unit": "NODE_OPTIONS='--max-old-space-size=4096' jest --testPathPattern=tests/unit",
        "test:integration": "NODE_OPTIONS='--max-old-space-size=4096' jest --testPathPattern=tests/integration",
        "test:e2e": "turbo test:e2e",
        "test:e2e:suite": "jest --config tests/e2e/jest.e2e.config.ts --testPathPattern",
        "test:cov": "NODE_OPTIONS='--max-old-space-size=4096' jest --coverage",
        "lint": "turbo lint",
        "lint:fix": "turbo lint:fix",
        "format": "prettier --write \"**/*.{ts,json,md,yaml,yml}\"",
        "format:check": "prettier --check \"**/*.{ts,json,md,yaml,yml}\"",
        "db:migrate": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:seed": "prisma db seed",
        "db:reset": "prisma migrate reset",
        "db:generate": "prisma generate",
        "db:studio": "prisma studio",
        "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
        "docker:dev:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --build",
        "docker:dev:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
        "docker:dev:build:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --build up -d",
        "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
        "docker:dev:clean": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down -v",
        "docker:up": "docker compose -f docker-compose.yml up -d",
        "docker:down": "docker compose -f docker-compose.yml down",
        "docker:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml up -d",
        "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
        "logs": "docker compose logs -f",
        "logs:all": "docker compose logs -f --tail=100",
        "logs:gateway": "docker logs nestlancer-gateway -f --tail=100",
        "logs:auth": "docker logs nestlancer-auth -f --tail=100",
        "logs:users": "docker logs nestlancer-users -f --tail=100",
        "logs:payments": "docker logs nestlancer-payments -f --tail=100",
        "logs:projects": "docker logs nestlancer-projects -f --tail=100",
        "logs:requests": "docker logs nestlancer-requests -f --tail=100",
        "logs:quotes": "docker logs nestlancer-quotes -f --tail=100",
        "logs:progress": "docker logs nestlancer-progress -f --tail=100",
        "logs:messaging": "docker logs nestlancer-messaging -f --tail=100",
        "logs:notifications": "docker logs nestlancer-notifications -f --tail=100",
        "logs:media": "docker logs nestlancer-media -f --tail=100",
        "logs:portfolio": "docker logs nestlancer-portfolio -f --tail=100",
        "logs:blog": "docker logs nestlancer-blog -f --tail=100",
        "logs:contact": "docker logs nestlancer-contact -f --tail=100",
        "logs:admin": "docker logs nestlancer-admin -f --tail=100",
        "logs:webhooks": "docker logs nestlancer-webhooks -f --tail=100",
        "logs:health": "docker logs nestlancer-health -f --tail=100",
        "logs:ws-gateway": "docker logs nestlancer-ws-gateway -f --tail=100",
        "logs:errors": "docker compose logs --tail=200 2>&1 | grep -i error",
        "clean": "turbo clean && rm -rf node_modules dist coverage .turbo",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.6.1",
        "@commitlint/config-conventional": "^19.6.0",
        "@nestjs/cli": "^10.4.9",
        "@nestjs/config": "^3.0.0",
        "@nestjs/schematics": "^10.2.3",
        "@nestjs/testing": "^10.4.15",
        "@types/amqplib": "^0.10.8",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.17.12",
        "@types/pg": "^8.16.0",
        "@typescript-eslint/eslint-plugin": "^8.20.0",
        "@typescript-eslint/parser": "^8.20.0",
        "amqplib": "^0.10.9",
        "axios": "^1.13.6",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-prettier": "^5.2.3",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "lint-staged": "^15.4.3",
        "null-loader": "^4.0.1",
        "prettier": "^3.4.2",
        "prisma": "^7.4.1",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "turbo": "^2.3.4",
        "typescript": "^5.7.3"
    },
    "prisma": {
        "seed": "ts-node prisma/seeds/index.ts"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.1",
        "@prisma/client": "^7.4.1",
        "pg": "^8.19.0",
        "prom-client": "^15.1.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "ts-loader": "^9.5.2",
        "webpack": "^5.97.1",
        "webpack-node-externals": "^3.0.0",
        "zod": "^3.22.0",
        "bcrypt": "^5.1.1",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "amqplib": "^0.10.4",
        "ioredis": "^5.10.0",
        "axios": "^1.7.9",
        "@nestjs/swagger": "^7.4.2",
        "@nestjs/passport": "^10.0.3",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "@nestjs/jwt": "^10.2.0",
        "@aws-sdk/client-s3": "^3.450.0",
        "@aws-sdk/s3-request-presigner": "^3.450.0",
        "meilisearch": "^0.36.0",
        "uuid": "^10.0.0",
        "otplib": "^12.0.1",
        "qrcode": "^1.5.3"
    }
}