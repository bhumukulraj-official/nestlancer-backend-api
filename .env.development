# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                          WS-GATEWAY                                         ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

WS_PORT=3100

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                            WORKERS                                          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                      workers/analytics-worker                              │
# └────────────────────────────────────────────────────────────────────────────┘
HOURLY_CRON=0 * * * *
DAILY_CRON=0 2 * * *
WEEKLY_CRON=0 3 * * 1
CACHE_TTL_HOURLY=3600
CACHE_TTL_DAILY=86400
USE_READ_REPLICA=false

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        workers/audit-worker                                │
# └────────────────────────────────────────────────────────────────────────────┘
AUDIT_BATCH_SIZE=50
AUDIT_FLUSH_INTERVAL_MS=5000
AUDIT_MAX_BUFFER_SIZE=500
AUDIT_FALLBACK_FILE_PATH=/tmp/audit-fallback.jsonl
AUDIT_RETRY_ON_FAILURE=true
AUDIT_QUEUE_NAME=audit.queue

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                         workers/cdn-worker                                 │
# └────────────────────────────────────────────────────────────────────────────┘
BATCH_WINDOW_MS=10000
MAX_BATCH_SIZE=30
RETRY_ON_RATE_LIMIT=true
CLOUDFLARE_API_TOKEN=dev-cloudflare-api-token-placeholder
CLOUDFLARE_ZONE_ID=dev-cloudflare-zone-id-placeholder

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                       workers/email-worker                                 │
# └────────────────────────────────────────────────────────────────────────────┘
EMAIL_CONCURRENCY=2
TEMPLATES_PATH=./src/templates
EMAIL_IDEMPOTENCY_TTL=86400

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                       workers/media-worker                                 │
# └────────────────────────────────────────────────────────────────────────────┘
MEDIA_CONCURRENCY=2
MEDIA_TEMP_DIR=/tmp/media-worker
MEDIA_WORKER_CLAMAV_HOST=localhost
MEDIA_WORKER_CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=60000
WEBP_QUALITY=80
MAX_PROCESSING_TIME_MS=300000

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                    workers/notification-worker                             │
# └────────────────────────────────────────────────────────────────────────────┘
NOTIFICATION_WORKER_REDIS_HOST=localhost
NOTIFICATION_WORKER_REDIS_PORT=6379
NOTIFICATION_WORKER_REDIS_PASSWORD=
REDIS_PUBSUB_PREFIX=ws:
NOTIFICATION_WORKER_VAPID_PUBLIC_KEY=dev-vapid-public-key-placeholder
NOTIFICATION_WORKER_VAPID_PRIVATE_KEY=dev-vapid-private-key-placeholder
NOTIFICATION_WORKER_VAPID_SUBJECT=mailto:dev@nestlancer.local
NOTIFICATION_CONCURRENCY=5

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                       workers/outbox-poller                                │
# └────────────────────────────────────────────────────────────────────────────┘
POLLING_INTERVAL_MS=5000
BATCH_SIZE=100
LOCK_TTL_SECONDS=10
STALE_THRESHOLD_MINUTES=60
LEADER_LOCK_KEY=outbox:poller:lock
OUTBOX_HOSTNAME=outbox-dev-1
OUTBOX_MAX_RETRIES=5
OUTBOX_RETRY_BACKOFF_MS=1000
OUTBOX_RETRY_BACKOFF_MAX_MS=300000

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                      workers/webhook-worker                                │
# └────────────────────────────────────────────────────────────────────────────┘
OUTGOING_TIMEOUT_MS=10000
WEBHOOK_WORKER_MAX_RETRIES=5
BACKOFF_BASE_SECONDS=10
BACKOFF_MULTIPLIER=3

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                           LIBS (EXTRA)                                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                           libs/outbox                                      │
# └────────────────────────────────────────────────────────────────────────────┘
OUTBOX_POLL_INTERVAL=5000
OUTBOX_BATCH_SIZE=100
OUTBOX_EXCHANGE=events

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        libs/audit (writer)                                 │
# └────────────────────────────────────────────────────────────────────────────┘
AUDIT_WORKER_BATCH_SIZE=50
AUDIT_WORKER_FLUSH_INTERVAL=5000