// =============================================================================
// Service Request Models
// =============================================================================

enum RequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  QUOTED
  ACCEPTED
  REJECTED
  CONVERTED_TO_PROJECT
  CHANGES_REQUESTED
  CANCELLED
}

model ProjectRequest {
  id                    String                 @id @default(uuid(7))
  userId                String
  assigneeId            String?
  title                 String
  description           String
  category              String
  budgetMin             Int?
  budgetMax             Int?
  budgetCurrency        String                 @default("INR")
  budgetFlexible        Boolean                @default(false)
  preferredStartDate    DateTime?
  deadline              DateTime?
  timelineFlexible      Boolean                @default(false)
  requirements          String[]
  technicalRequirements Json?
  additionalInfo        String?
  timeframe             String?
  status                RequestStatus          @default(DRAFT)
  submittedAt           DateTime?
  deletedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignee              User?                  @relation("RequestAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  quote                 Quote?
  statusHistory         RequestStatusHistory[]
  adminNotes            AdminNote[]
  attachments           RequestAttachment[]

  @@index([userId])
  @@index([status])
}

model RequestAttachment {
  id        String         @id @default(uuid(7))
  requestId String
  filename  String
  fileUrl   String
  mimeType  String
  size      Int
  createdAt DateTime       @default(now())
  request   ProjectRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model RequestStatusHistory {
  id        String         @id @default(uuid(7))
  requestId String
  status    RequestStatus
  note      String?
  createdAt DateTime       @default(now())
  request   ProjectRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model AdminNote {
  id        String         @id @default(uuid(7))
  requestId String
  authorId  String
  content   String
  createdAt DateTime       @default(now())
  request   ProjectRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author    User           @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([requestId])
  @@index([authorId])
}
