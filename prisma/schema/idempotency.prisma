// =============================================================================
// Idempotency Key Model (ADR-007)
// =============================================================================

model IdempotencyKey {
  id           String    @id @default(cuid())
  key          String    @unique
  path         String
  method       String
  requestHash  String?
  responseCode Int?
  responseBody Json?
  lockedAt     DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([expiresAt])
}
