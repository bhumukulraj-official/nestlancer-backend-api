// =============================================================================
// Payment Domain Models
// =============================================================================

enum PaymentStatus {
  CREATED
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  DISPUTED
  CANCELLED
}

model Payment {
  id              String        @id @default(uuid(7))
  projectId       String
  milestoneId     String?
  clientId        String
  amount          Int
  currency        String        @default("INR")
  status          PaymentStatus @default(CREATED)
  method          String?
  intentId        String?       @unique
  externalId      String?
  externalStatus  String?
  providerDetails Json?
  refundStatus    String?
  amountRefunded  Int           @default(0)
  receiptNumber   String?
  receiptUrl      String?
  invoiceNumber   String?
  invoiceUrl      String?
  customNotes     String?
  paidAt          DateTime?
  failureReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project         Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  milestone       Milestone?    @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  client          User          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  refunds         Refund[]
  disputes        Dispute[]

  @@index([projectId])
  @@index([clientId])
  @@index([externalId])
  @@index([status])
}

model Refund {
  id              String   @id @default(uuid(7))
  paymentId       String
  externalId      String?  @unique
  amount          Int
  currency        String   @default("INR")
  type            String
  reason          String?
  status          String
  providerDetails Json?
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model SavedPaymentMethod {
  id              String   @id @default(uuid(7))
  userId          String
  provider        String   @default("razorpay")
  type            String   // card, upi, netbanking, wallet
  tokenId         String?  // Provider token for saved method
  last4           String?  // Last 4 digits for cards
  cardBrand       String?  // visa, mastercard, etc.
  cardExpMonth    Int?
  cardExpYear     Int?
  upiVpa          String?  // UPI VPA handle
  bankName        String?  // For netbanking
  walletProvider  String?  // paytm, phonepe, etc.
  nickname        String?  // User-defined name
  isDefault       Boolean  @default(false)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tokenId])
  @@index([userId])
}

model Dispute {
  id              String   @id @default(uuid(7))
  paymentId       String
  externalId      String   @unique
  reason          String?
  status          String
  amount          Int
  currency        String   @default("INR")
  evidenceDueBy   DateTime?
  providerDetails Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}
