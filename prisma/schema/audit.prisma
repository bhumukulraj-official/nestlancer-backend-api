// =============================================================================
// Audit Domain Models
// =============================================================================

model AuditLog {
  id           String   @id @default(uuid(7))
  userId       String?
  action       String
  category     String
  description  String
  resourceType String?
  resourceId   String?
  metadata     Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([resourceType, resourceId])
}
