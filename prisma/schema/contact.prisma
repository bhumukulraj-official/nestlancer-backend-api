// =============================================================================
// Contact Domain Models
// =============================================================================

enum ContactStatus {
  NEW
  READ
  RESPONDED
  ARCHIVED
  SPAM
}

enum ContactSubject {
  GENERAL
  SUPPORT
  BUG_REPORT
  PARTNERSHIP
  OTHER
}

model ContactMessage {
  id        String         @id @default(cuid())
  ticketId  String         @unique
  name      String
  email     String
  subject   ContactSubject @default(GENERAL)
  message   String
  status    ContactStatus  @default(NEW)
  ipInfo    Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([ticketId])
  @@index([email])
}
