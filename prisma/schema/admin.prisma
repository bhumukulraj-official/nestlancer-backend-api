// =============================================================================
// Admin Domain Models
// =============================================================================

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  isPublic    Boolean  @default(false)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin       User?    @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([key])
}

model FeatureFlag {
  id                 String   @id @default(cuid())
  flag               String   @unique
  enabled            Boolean  @default(false)
  description        String?
  rolloutPercentage  Int      @default(0)
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([flag])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  subject     String
  body        String
  variables   Json?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}
