{
  "info": {
    "name": "Nestlancer API",
    "description": "Nestlancer freelancing platform API collection.\n\n**Setup:**\n1. Import this collection\n2. Select 'Local' or 'Staging' environment\n3. Run 'Auth / Register' or 'Auth / Login' to get tokens\n4. Access token auto-saved to environment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "nestlancer",
    "version": "1.1.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Readiness Probe",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health/ready",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Liveness Probe",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health/live",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.environment.set('accessToken', json.data.accessToken);",
                  "  pm.environment.set('refreshToken', json.data.refreshToken);",
                  "  pm.environment.set('userId', json.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.environment.set('accessToken', json.data.accessToken);",
                  "  pm.environment.set('refreshToken', json.data.refreshToken);",
                  "  pm.environment.set('userId', json.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": { "method": "GET", "url": "{{baseUrl}}/users/me" }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/me",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Updated\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Requests",
      "item": [
        {
          "name": "Create Request",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/requests",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Website Design\",\n  \"description\": \"Need a modern landing page\",\n  \"category\": \"WEB_DEVELOPMENT\"\n}"
            }
          }
        },
        {
          "name": "List My Requests",
          "request": { "method": "GET", "url": "{{baseUrl}}/requests?page=1&limit=20" }
        },
        {
          "name": "Get Request",
          "request": { "method": "GET", "url": "{{baseUrl}}/requests/{{requestId}}" }
        }
      ]
    },
    {
      "name": "Portfolio (Public)",
      "item": [
        {
          "name": "List Portfolio Items",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/portfolio?page=1&limit=20",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Portfolio Item",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/portfolio/{{portfolioSlug}}",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Blog (Public)",
      "item": [
        {
          "name": "List Blog Posts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/blog/posts?page=1&limit=20",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Blog Post",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/blog/posts/{{postSlug}}",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Contact (Public)",
      "item": [
        {
          "name": "Submit Contact Form",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/contact",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"subject\": \"PROJECT_DISCUSSION\",\n  \"message\": \"I'd like to discuss a project\"\n}"
            }
          }
        }
      ]
    }
  ]
}
