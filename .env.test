# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                       NESTLANCER — TEST ENVIRONMENT                         ║
# ║                                                                            ║
# ║  Unit & integration tests. Isolated DB, minimal workers, fast timeouts.    ║
# ║  All infrastructure points to test-specific databases/indices.             ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                          CORE / APP SETTINGS                               │
# └────────────────────────────────────────────────────────────────────────────┘
NODE_ENV=test
PORT=0
GATEWAY_PORT=0
APP_NAME=Nestlancer-Test
API_VERSION=v1
FRONTEND_URL=http://localhost:4200
CORRELATION_ID_HEADER=X-Request-ID

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                             LOGGING                                        │
# └────────────────────────────────────────────────────────────────────────────┘
LOG_LEVEL=warn
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_FILE_PATH=./logs/test.log

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                             DATABASE                                       │
# └────────────────────────────────────────────────────────────────────────────┘
DATABASE_URL=postgresql://nestlancer_test:testpassword@localhost:5432/nestlancer_test
DATABASE_READ_URL=
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5
DATABASE_QUERY_TIMEOUT=3000

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                               REDIS                                        │
# └────────────────────────────────────────────────────────────────────────────┘
REDIS_URL=redis://localhost:6379/10
REDIS_CACHE_URL=redis://localhost:6379/10
REDIS_PUBSUB_URL=redis://localhost:6379/11
REDIS_MAX_RETRIES=1
REDIS_RETRY_DELAY=100

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                             RABBITMQ                                       │
# └────────────────────────────────────────────────────────────────────────────┘
RABBITMQ_URL=amqp://guest:guest@localhost:5672/test
RABBITMQ_EXCHANGE_EVENTS=events.test
RABBITMQ_EXCHANGE_WEBHOOKS=webhooks.test
RABBITMQ_PREFETCH=5
RABBITMQ_RETRY_DELAY=100
RABBITMQ_MAX_RETRIES=1

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                          JWT / AUTH TOKENS                                 │
# └────────────────────────────────────────────────────────────────────────────┘
JWT_ACCESS_SECRET=test-access-secret-must-be-at-least-32-chars!!
JWT_REFRESH_SECRET=test-refresh-secret-must-be-at-least-32-chars!!
JWT_ACCESS_EXPIRY=5m
JWT_REFRESH_EXPIRY=1h
JWT_ALGORITHM=HS256

JWT_ACCESS_PUBLIC_KEY=
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_EXPIRES_IN=300
JWT_REFRESH_PUBLIC_KEY=
JWT_REFRESH_PRIVATE_KEY=
JWT_REFRESH_EXPIRES_IN=3600
JWT_ISSUER=nestlancer-auth-test
JWT_AUDIENCE=nestlancer-api-test

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                          CORS & RATE LIMITING                              │
# └────────────────────────────────────────────────────────────────────────────┘
CORS_ORIGINS=http://localhost:4200
CORS_CREDENTIALS=true
CORS_MAX_AGE=0

RATE_LIMIT_ANONYMOUS=10000
RATE_LIMIT_ANONYMOUS_BURST=10000
RATE_LIMIT_USER=10000
RATE_LIMIT_USER_BURST=10000
RATE_LIMIT_PAID=10000
RATE_LIMIT_PAID_BURST=10000
RATE_LIMIT_ADMIN=10000
RATE_LIMIT_ADMIN_BURST=10000
RATE_LIMIT_WEBHOOK=10000

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        STORAGE (S3 / B2 / LOCAL)                           │
# └────────────────────────────────────────────────────────────────────────────┘
STORAGE_PROVIDER=local
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf

B2_KEY_ID=
B2_APPLICATION_KEY=
B2_ENDPOINT=s3.us-east-005.backblazeb2.com
B2_REGION=us-east-1
B2_BUCKET_PRIVATE=nestlancer-test-private
B2_BUCKET_PUBLIC=nestlancer-test-public
B2_PRESIGNED_URL_EXPIRY=60

LOCAL_STORAGE_PATH=./data/test-storage
LOCAL_STORAGE_URL=http://localhost:3000/files

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                           EMAIL / MAIL                                     │
# └────────────────────────────────────────────────────────────────────────────┘
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
ZEPTOMAIL_URL=
ZEPTOMAIL_TOKEN=
FROM_EMAIL=test@nestlancer.local
FROM_NAME=Nestlancer Test
REPLY_TO=test@nestlancer.local

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                           RAZORPAY                                         │
# └────────────────────────────────────────────────────────────────────────────┘
RAZORPAY_KEY_ID=rzp_test_testplaceholder
RAZORPAY_KEY_SECRET=test_razorpay_secret_placeholder
RAZORPAY_WEBHOOK_SECRET=test_razorpay_webhook_placeholder
RAZORPAY_CURRENCY=INR

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                         MEILISEARCH                                        │
# └────────────────────────────────────────────────────────────────────────────┘
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=test-meilisearch-master-key

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                         ENCRYPTION                                         │
# └────────────────────────────────────────────────────────────────────────────┘
ENCRYPTION_KEY=abcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                      SECRETS LOADER (INFISICAL)                            │
# └────────────────────────────────────────────────────────────────────────────┘
INFISICAL_TOKEN=
INFISICAL_ENV=test

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                          SERVICE-SPECIFIC CONFIG                            ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                          services/auth                                     │
# └────────────────────────────────────────────────────────────────────────────┘
BCRYPT_SALT_ROUNDS=4
MAX_FAILED_LOGIN_ATTEMPTS=100
LOCKOUT_DURATION_MS=1000
FAILED_LOGIN_COOLDOWN_WINDOW_MS=60000
OTP_EXPIRES_IN_MS=300000
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_BYPASS_TOKEN=test-bypass-token
EMAIL_VERIFY_EXPIRES_IN=86400
PASSWORD_RESET_EXPIRES_IN=3600

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                          services/blog                                     │
# └────────────────────────────────────────────────────────────────────────────┘
POSTS_PER_PAGE=5
MAX_COMMENT_LENGTH=2000
COMMENT_EDIT_WINDOW_MINUTES=30
MAX_COMMENT_DEPTH=3
MAX_REVISIONS_PER_POST=10
READING_WPM=200
RSS_ITEMS_COUNT=10
VIEW_DEBOUNCE_HOURS=0
SPAM_SCORE_THRESHOLD=0.7

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                         services/health                                    │
# └────────────────────────────────────────────────────────────────────────────┘
HEALTH_CACHE_TTL=0
HEALTH_TIMEOUT_DB=1000
HEALTH_TIMEOUT_CACHE=500
HEALTH_TIMEOUT_QUEUE=1000
HEALTH_TIMEOUT_STORAGE=1000
HEALTH_TIMEOUT_EXTERNAL=2000
HEALTH_THRESHOLD_MEMORY_HEAP=268435456
HEALTH_THRESHOLD_MEMORY_RSS=536870912
HEALTH_THRESHOLD_DISK_PERCENT=0.95
SERVICE_REGISTRY_URL=http://localhost:3000/api/v1/registry
HEALTH_E2E_DISABLE_AUTH=false

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                          services/media                                    │
# └────────────────────────────────────────────────────────────────────────────┘
S3_PRIVATE_BUCKET=nestlancer-test-private
S3_PUBLIC_BUCKET=nestlancer-test-public
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CDN_DOMAIN=localhost

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        services/messaging                                  │
# └────────────────────────────────────────────────────────────────────────────┘
MAX_MESSAGE_SIZE=1048576
MAX_ATTACHMENTS=5
MESSAGING_REDIS_URL=redis://localhost:6379/12

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                      services/notifications                                │
# └────────────────────────────────────────────────────────────────────────────┘
VAPID_PUBLIC_KEY=test-vapid-public-key
VAPID_PRIVATE_KEY=test-vapid-private-key
VAPID_SUBJECT=mailto:test@nestlancer.local

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        services/payments                                   │
# └────────────────────────────────────────────────────────────────────────────┘
DEFAULT_CURRENCY=USD
SUPPORTED_CURRENCIES=USD,INR
RECEIPT_PDF_PREFIX=TEST-RCPT-
INVOICE_PDF_PREFIX=TEST-INV-

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                       services/portfolio                                   │
# └────────────────────────────────────────────────────────────────────────────┘
MAX_IMAGES_PER_ITEM=5
MAX_TAGS_PER_ITEM=5
PUBLIC_CACHE_TTL=0
FEATURED_CACHE_TTL=0
# VIEW_DEBOUNCE_HOURS already set above (blog section — shared key)

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        services/progress                                   │
# └────────────────────────────────────────────────────────────────────────────┘
MAX_DELIVERABLE_SIZE_MB=10
APPROVAL_WINDOW_DAYS=7
MAX_REVISIONS_PER_MILESTONE=3

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        services/projects                                   │
# └────────────────────────────────────────────────────────────────────────────┘
DELIVERABLES_S3_BUCKET=nestlancer-test-deliverables

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                         services/quotes                                    │
# └────────────────────────────────────────────────────────────────────────────┘
PDF_TEMPLATE_DIR=src/templates/pdf
QUOTES_S3_BUCKET=nestlancer-test-quotes
DEFAULT_QUOTE_VALIDITY_DAYS=30

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        services/requests                                   │
# └────────────────────────────────────────────────────────────────────────────┘
ATTACHMENT_MAX_SIZE=1048576
ATTACHMENT_MAX_COUNT=3
ATTACHMENT_S3_BUCKET=nestlancer-test-requests
QUOTE_EXPIRATION_DAYS=14

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                          services/users                                    │
# └────────────────────────────────────────────────────────────────────────────┘
AVATAR_MAX_SIZE=1048576
AVATAR_S3_BUCKET=nestlancer-test-avatars
GDPR_EXPORT_LIMIT_DAYS=30
SOFT_DELETE_GRACE_PERIOD_DAYS=7

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        services/webhooks                                   │
# └────────────────────────────────────────────────────────────────────────────┘
CLOUDFLARE_WEBHOOK_SECRET=test-cloudflare-webhook-secret
WEBHOOK_MAX_RETRIES=2
WEBHOOK_RETRY_BACKOFF_MULTIPLIER=1
WEBHOOK_DEAD_LETTER_TTL_DAYS=1
WEBHOOK_RAW_BODY_SIZE_LIMIT=1mb

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                            GATEWAY                                          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

AUTH_SERVICE_URL=http://localhost:3001
USERS_SERVICE_URL=http://localhost:3002
PAYMENTS_SERVICE_URL=http://localhost:3003
WEBHOOKS_SERVICE_URL=http://localhost:3004
ADMIN_SERVICE_URL=http://localhost:3005
REQUESTS_SERVICE_URL=http://localhost:3006
QUOTES_SERVICE_URL=http://localhost:3007
PROJECTS_SERVICE_URL=http://localhost:3008
PROGRESS_SERVICE_URL=http://localhost:3009
MESSAGING_SERVICE_URL=http://localhost:3010
NOTIFICATIONS_SERVICE_URL=http://localhost:3011
MEDIA_SERVICE_URL=http://localhost:3012
PORTFOLIO_SERVICE_URL=http://localhost:3013
BLOG_SERVICE_URL=http://localhost:3014
CONTACT_SERVICE_URL=http://localhost:3015
HEALTH_SERVICE_URL=http://localhost:3016

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                          WS-GATEWAY                                         ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

WS_PORT=0

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                            WORKERS                                          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                      workers/analytics-worker                              │
# └────────────────────────────────────────────────────────────────────────────┘
HOURLY_CRON=0 * * * *
DAILY_CRON=0 2 * * *
WEEKLY_CRON=0 3 * * 1
CACHE_TTL_HOURLY=60
CACHE_TTL_DAILY=120
USE_READ_REPLICA=false
REPORT_S3_BUCKET=nestlancer-test-reports

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        workers/audit-worker                                │
# └────────────────────────────────────────────────────────────────────────────┘
AUDIT_BATCH_SIZE=10
AUDIT_FLUSH_INTERVAL_MS=1000
AUDIT_MAX_BUFFER_SIZE=50
AUDIT_FALLBACK_FILE_PATH=/tmp/audit-fallback-test.jsonl
AUDIT_RETRY_ON_FAILURE=false
AUDIT_QUEUE_NAME=audit.queue.test

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                         workers/cdn-worker                                 │
# └────────────────────────────────────────────────────────────────────────────┘
BATCH_WINDOW_MS=1000
MAX_BATCH_SIZE=5
RETRY_ON_RATE_LIMIT=false
CLOUDFLARE_API_TOKEN=test-cf-api-token
CLOUDFLARE_ZONE_ID=test-cf-zone-id

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                       workers/email-worker                                 │
# └────────────────────────────────────────────────────────────────────────────┘
EMAIL_CONCURRENCY=1
TEMPLATES_PATH=./src/templates
EMAIL_IDEMPOTENCY_TTL=60

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                       workers/media-worker                                 │
# └────────────────────────────────────────────────────────────────────────────┘
MEDIA_CONCURRENCY=1
MEDIA_TEMP_DIR=/tmp/media-worker-test
STORAGE_PRIVATE_BUCKET=nestlancer-test-private
MEDIA_WORKER_CLAMAV_HOST=localhost
MEDIA_WORKER_CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=5000
WEBP_QUALITY=50
MAX_PROCESSING_TIME_MS=30000

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                    workers/notification-worker                             │
# └────────────────────────────────────────────────────────────────────────────┘
NOTIFICATION_WORKER_REDIS_HOST=localhost
NOTIFICATION_WORKER_REDIS_PORT=6379
NOTIFICATION_WORKER_REDIS_PASSWORD=
REDIS_PUBSUB_PREFIX=ws:test:
NOTIFICATION_WORKER_VAPID_PUBLIC_KEY=test-vapid-pub
NOTIFICATION_WORKER_VAPID_PRIVATE_KEY=test-vapid-priv
NOTIFICATION_WORKER_VAPID_SUBJECT=mailto:test@nestlancer.local
NOTIFICATION_CONCURRENCY=2

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                       workers/outbox-poller                                │
# └────────────────────────────────────────────────────────────────────────────┘
POLLING_INTERVAL_MS=1000
BATCH_SIZE=10
LOCK_TTL_SECONDS=5
STALE_THRESHOLD_MINUTES=5
LEADER_LOCK_KEY=outbox:poller:lock:test
OUTBOX_HOSTNAME=outbox-test-1
OUTBOX_MAX_RETRIES=2
OUTBOX_RETRY_BACKOFF_MS=100
OUTBOX_RETRY_BACKOFF_MAX_MS=1000

# ┌────────────────────────────────────────────────────────────────────────────┐
# │                      workers/webhook-worker                                │
# └────────────────────────────────────────────────────────────────────────────┘
OUTGOING_TIMEOUT_MS=3000
WEBHOOK_WORKER_MAX_RETRIES=2
BACKOFF_BASE_SECONDS=1
BACKOFF_MULTIPLIER=1

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                           LIBS (EXTRA)                                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

OUTBOX_POLL_INTERVAL=1000
OUTBOX_BATCH_SIZE=10
OUTBOX_EXCHANGE=events.test

AUDIT_WORKER_BATCH_SIZE=10
AUDIT_WORKER_FLUSH_INTERVAL=1000