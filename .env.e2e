# ═══════════════════════════════════════════════════════════════
# Nestlancer – E2E Environment Configuration (Local Docker)
# ═══════════════════════════════════════════════════════════════

# ── General / Shared ──────────────────────────────────────────
NODE_ENV=test
APP_NAME=Nestlancer
API_VERSION=v1
API_PREFIX=/api
LOG_LEVEL=error
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_FILE_PATH=./logs/app.log
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
ENCRYPTION_KEY=43e6a09def0fbb2de4aa7bda0fd1d9db059268a6eb22ae759727b9023fca30a9

# ── Database (E2E Docker at port 5433) ────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/nestlancer_e2e?schema=public
DATABASE_READ_URL=postgresql://postgres:postgres@localhost:5433/nestlancer_e2e?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT=10000
DATABASE_CONNECTION_TIMEOUT=5000

# ── Redis (E2E Docker) ───────────────────────────────────────
REDIS_CACHE_URL=redis://localhost:6380/0
REDIS_CACHE_TTL_DEFAULT=300
REDIS_CACHE_MAX_ITEMS=10000
REDIS_PUBSUB_URL=redis://localhost:6381/1

# ── RabbitMQ (E2E Docker at port 5673) ───────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5673
RABBITMQ_EXCHANGE_EVENTS=events
RABBITMQ_EXCHANGE_WEBHOOKS=webhooks
RABBITMQ_PREFETCH=10
RABBITMQ_RETRY_DELAY=5000
RABBITMQ_MAX_RETRIES=3

# ── JWT / Auth ───────────────────────────────────────────────
JWT_ACCESS_SECRET=+yxhES59fFPRPAyWpazRVHnD10MD94oYCtVs7pZsXjQ=
JWT_REFRESH_SECRET=OTTlPc7dX1dER/YNmvBigFMzShfZdQWirhSmkPzVkCI=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=nestlancer-auth
JWT_AUDIENCE=nestlancer-api

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
ALLOWED_ORIGINS=http://localhost:3000

# ── WS Gateway Internal ─────────────────────────────────────
WS_GATEWAY_INTERNAL_URL=http://localhost:3100

# ═══════════════════════════════════════════════════════════════
# Gateway
# ═══════════════════════════════════════════════════════════════
GATEWAY_PORT=3000
CORRELATION_ID_HEADER=X-Request-ID
RATE_LIMIT_ANONYMOUS=100
RATE_LIMIT_ANONYMOUS_BURST=10
RATE_LIMIT_USER=1000
RATE_LIMIT_USER_BURST=30
RATE_LIMIT_PAID=5000
RATE_LIMIT_PAID_BURST=100
RATE_LIMIT_ADMIN=10000
RATE_LIMIT_ADMIN_BURST=200
RATE_LIMIT_WEBHOOK=5000
CORS_ORIGINS=http://localhost:3000,http://localhost:4000
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# ── Service URLs (gateway routing) ───────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
USERS_SERVICE_URL=http://localhost:3002
PAYMENTS_SERVICE_URL=http://localhost:3003
WEBHOOKS_SERVICE_URL=http://localhost:3004
ADMIN_SERVICE_URL=http://localhost:3005
REQUESTS_SERVICE_URL=http://localhost:3006
QUOTES_SERVICE_URL=http://localhost:3007
PROJECTS_SERVICE_URL=http://localhost:3008
PROGRESS_SERVICE_URL=http://localhost:3009
MESSAGING_SERVICE_URL=http://localhost:3010
NOTIFICATIONS_SERVICE_URL=http://localhost:3011
MEDIA_SERVICE_URL=http://localhost:3012
PORTFOLIO_SERVICE_URL=http://localhost:3013
BLOG_SERVICE_URL=http://localhost:3014
CONTACT_SERVICE_URL=http://localhost:3015
HEALTH_SERVICE_URL=http://localhost:3016

# ═══════════════════════════════════════════════════════════════
# Services – Ports
# ═══════════════════════════════════════════════════════════════
AUTH_SERVICE_PORT=3001
USERS_SERVICE_PORT=3002
PAYMENTS_SERVICE_PORT=3003
WEBHOOKS_SERVICE_PORT=3004
ADMIN_SERVICE_PORT=3005
REQUESTS_SERVICE_PORT=3006
QUOTES_SERVICE_PORT=3007
PROJECTS_SERVICE_PORT=3008
PROGRESS_SERVICE_PORT=3009
MESSAGING_SERVICE_PORT=3010
NOTIFICATIONS_SERVICE_PORT=3011
MEDIA_SERVICE_PORT=3012
PORTFOLIO_SERVICE_PORT=3013
BLOG_SERVICE_PORT=3014
CONTACT_SERVICE_PORT=3015
HEALTH_SERVICE_PORT=3016

