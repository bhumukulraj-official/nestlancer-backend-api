{
    "moduleFileExtensions": [
        "js",
        "json",
        "ts"
    ],
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": ".e2e-spec.ts$",
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
        "^@nestlancer/common$": "<rootDir>/../../libs/common/src",
        "^@nestlancer/config$": "<rootDir>/../../libs/config/src",
        "^@nestlancer/logger$": "<rootDir>/../../libs/logger/src",
        "^@nestlancer/metrics$": "<rootDir>/../../libs/metrics/src",
        "^@nestlancer/tracing$": "<rootDir>/../../libs/tracing/src",
        "^@nestlancer/database$": "<rootDir>/../../libs/database/src",
        "^@nestlancer/queue$": "<rootDir>/../../libs/queue/src",
        "^@nestlancer/outbox$": "<rootDir>/../../libs/outbox/src",
        "^@nestlancer/cache$": "<rootDir>/../../libs/cache/src",
        "^@nestlancer/auth-lib$": "<rootDir>/../../libs/auth-lib/src",
        "^@nestlancer/idempotency$": "<rootDir>/../../libs/idempotency/src"
    }
}