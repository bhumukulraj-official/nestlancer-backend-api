{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2021",
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "strictBindCallApply": true,
        "forceConsistentCasingInFileNames": true,
        "noFallbackBumps": true,
        "paths": {
            "@nestlancer/common": [
                "../../libs/common/src"
            ],
            "@nestlancer/config": [
                "../../libs/config/src"
            ],
            "@nestlancer/logger": [
                "../../libs/logger/src"
            ],
            "@nestlancer/metrics": [
                "../../libs/metrics/src"
            ],
            "@nestlancer/tracing": [
                "../../libs/tracing/src"
            ],
            "@nestlancer/health-lib": [
                "../../libs/health-lib/src"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "dist",
        "tests"
    ]
}