# Nestlancer Code Owners
# Each line is a file pattern followed by one or more owners.
# Order matters – later rules override earlier ones.

# ──────────────────────────────────────────────
# Default – Backend Lead reviews everything
# ──────────────────────────────────────────────
* @backend-lead

# ──────────────────────────────────────────────
# Critical Services
# ──────────────────────────────────────────────
services/auth/ @backend-lead
services/payments/ @backend-lead
services/users/ @backend-lead

# ──────────────────────────────────────────────
# Shared Libraries – Platform Team
# ──────────────────────────────────────────────
libs/* @platform-team

# ──────────────────────────────────────────────
# Gateway
# ──────────────────────────────────────────────
gateway/ @backend-lead @platform-team
ws-gateway/ @backend-lead @platform-team

# ──────────────────────────────────────────────
# Database & Prisma
# ──────────────────────────────────────────────
prisma/ @backend-lead
prisma/migrations/ @backend-lead

# ──────────────────────────────────────────────
# DevOps – Infrastructure & Deployment
# ──────────────────────────────────────────────
deploy/ @devops-team
docker/ @devops-team
docker-compose*.yml @devops-team
Makefile @devops-team

# ──────────────────────────────────────────────
# CI/CD & GitHub Config
# ──────────────────────────────────────────────
.github/ @admin
.github/workflows/ @devops-team @admin

# ──────────────────────────────────────────────
# Scripts
# ──────────────────────────────────────────────
scripts/ @devops-team @backend-lead

# ──────────────────────────────────────────────
# Documentation
# ──────────────────────────────────────────────
docs/ @backend-lead
docs/architecture/ @backend-lead @platform-team
docs/runbooks/ @devops-team

# ──────────────────────────────────────────────
# Root Configuration
# ──────────────────────────────────────────────
package.json @backend-lead
pnpm-workspace.yaml @backend-lead
turbo.json @backend-lead
tsconfig.base.json @platform-team
