{
    "name": "@nestlancer/analytics-worker",
    "version": "1.0.0",
    "description": "Nestlancer Analytics Worker",
    "author": "Nestlancer Team",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:unit": "jest --testPathPattern=tests/unit",
        "test:integration": "jest --testPathPattern=tests/integration"
    },
    "dependencies": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/config": "^3.1.1",
        "@nestjs/schedule": "^4.0.0",
        "@nestlancer/common": "workspace:*",
        "@nestlancer/config": "workspace:*",
        "@nestlancer/database": "workspace:*",
        "@nestlancer/cache": "workspace:*",
        "@nestlancer/queue": "workspace:*",
        "@nestlancer/logger": "workspace:*",
        "@nestlancer/metrics": "workspace:*",
        "@nestlancer/tracing": "workspace:*",
        "@nestlancer/storage": "workspace:*",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.1",
        "pdfkit": "^0.13.0",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.0.0",
        "@nestjs/schematics": "^10.0.0",
        "@nestjs/testing": "^10.0.0",
        "@types/jest": "^29.5.2",
        "@types/node": "^20.3.1",
        "@types/pdfkit": "^0.13.3",
        "eslint": "^8.42.0",
        "jest": "^29.5.0",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.4.3",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3"
    }
}