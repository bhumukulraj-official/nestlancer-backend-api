{
  "name": "@nestlancer/media-worker",
  "version": "1.0.0",
  "description": "Nestlancer Media Worker",
  "author": "Nestlancer Team",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --config e2e/jest.e2e.config.ts --runInBand",
    "dev": "pnpm run start:dev"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestlancer/cache": "workspace:*",
    "@nestlancer/common": "workspace:*",
    "@nestlancer/config": "workspace:*",
    "@nestlancer/database": "workspace:*",
    "@nestlancer/logger": "workspace:*",
    "@nestlancer/metrics": "workspace:*",
    "@nestlancer/queue": "workspace:*",
    "@nestlancer/storage": "workspace:*",
    "@nestlancer/tracing": "workspace:*",
    "bullmq": "^5.0.0",
    "clamav.js": "^0.12.0",
    "fluent-ffmpeg": "^2.1.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sharp": "^0.32.6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}