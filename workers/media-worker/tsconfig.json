{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "baseUrl": "./",
        "allowSyntheticDefaultImports": true,
        "strictPropertyInitialization": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noImplicitReturns": false
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "tests"]
}
