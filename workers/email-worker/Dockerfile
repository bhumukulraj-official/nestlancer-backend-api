FROM node:20-alpine AS builder

WORKDIR /app
RUN corepack enable && corepack prepare pnpm@8.15.5 --activate

COPY turbo.json pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY libs/ ./libs/
COPY workers/email-worker/ ./workers/email-worker/
COPY prisma/ ./prisma/

RUN pnpm install --frozen-lockfile
RUN pnpm --filter @nestlancer/database generate
RUN pnpm --filter @nestlancer/email-worker build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV production
RUN apk add --no-cache curl

COPY --from=builder /app/pnpm-lock.yaml ./
COPY --from=builder /app/package.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/libs ./libs
COPY --from=builder /app/workers/email-worker/package.json ./workers/email-worker/
COPY --from=builder /app/workers/email-worker/dist ./workers/email-worker/dist
COPY --from=builder /app/workers/email-worker/node_modules ./workers/email-worker/node_modules
COPY --from=builder /app/prisma ./prisma

WORKDIR /app/workers/email-worker
CMD ["node", "dist/main.js"]
